# JobFit Agent environment variables
# Copy this file to .env if you want local shell helpers.
# Do not commit real API keys.

# LLM mode:
# mock: use local mock response, no API key needed
# deepseek: use DeepSeek API
# openai: use OpenAI API
JOBFIT_LLM_MODE=mock

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini